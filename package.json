{
  "name": "@sharpbits/react-interaction-hooks",
  "version": "0.2.7",
  "description": "A collection of 63 React hooks for UI interactions — pointer, touch, keyboard, focus, scroll, resize, clipboard, device sensors, and more. Zero dependencies, tree-shakeable, lightweight, and blazing fast.",
  "sideEffects": false,
  "author": "sharp0637794267@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/271043/react-interaction-hooks.git"
  },
  "homepage": "https://271043.github.io/react-interaction-hooks/",
  "keywords": [
    "react",
    "hooks",
    "useOutsideClick",
    "useHover",
    "useScrollLock",
    "useKeyCombo",
    "useLongPress",
    "useDrag",
    "useSwipe",
    "useDoubleTap",
    "usePinch",
    "usePointerPosition",
    "useKeyPress",
    "useFocusTrap",
    "useArrowNavigation",
    "useFocusWithin",
    "useIntersectionObserver",
    "useIdle",
    "useCopyToClipboard",
    "useMediaQuery",
    "useScrollPosition",
    "useScrollDirection",
    "useScrollProgress",
    "useResizeObserver",
    "useWindowSize",
    "useDropZone",
    "useContextMenu",
    "useMouseLeaveWindow",
    "useDeviceOrientation",
    "useGeolocation",
    "useNetworkStatus",
    "useBattery",
    "useVibrate",
    "usePageVisibility",
    "useTextSelection",
    "ui",
    "interaction",
    "accessibility",
    "touch",
    "keyboard",
    "sensors"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "demo": "vite",
    "demo:build": "vite build",
    "demo:preview": "vite preview --open",
    "release": "npm run build && npm version patch && git push && git push --tags && npm publish --access public",
    "deploy": "vite build && gh-pages -d dist-demo"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
